{
  "name": "warpgate-cli",
  "version": "0.1.1",
  "description": "Quick-access terminal picker for Warpgate SSH targets.",
  "url": "https://github.com/schmidfelix/warpgate-cli",
  "type": "module",
  "license": "MIT",
  "bin": {
    "warpgate-cli": "src/cli.tsx"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "os": [
    "darwin"
  ],
  "keywords": [
    "warpgate",
    "ssh",
    "tui",
    "cli",
    "tableplus"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "bun run src/cli.tsx",
    "build": "bun build src/cli.tsx --compile --target=bun-darwin-arm64 --outfile=warpgate-cli",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "react-devtools-core": "^7.0.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "ink": "^7.0.1",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.5"
  }
}
